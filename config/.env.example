APP_ENV=production
APP_NAME=Falschcard

# Database (MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=falschcard
DB_USER=falschcard_user
DB_PASS=change_this_password

# Encryption key for Gemini API keys stored at rest.
# Generate with: openssl rand -base64 32
# MUST be exactly 32 bytes after base64-decode (i.e. 44 base64 chars).
APP_CRYPTO_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# CORS — set to the domain that serves the frontend in production.
# In dev, Vite proxies /api so this is not needed.
CORS_ORIGIN=https://yourdomain.example.com

# AI (Gemini) request tuning — all optional, sensible defaults applied if omitted.
AI_TIMEOUT=30          # seconds for non-streaming calls (evaluate, fix-import, list models)
AI_STREAM_TIMEOUT=120  # seconds for streaming calls (review, tutor)
AI_MAX_RETRIES=2       # extra attempts on transient errors (429 / 5xx / transport)
AI_RETRY_BASE_MS=400   # base backoff in ms; grows exponentially with jitter
